{
  "name": "openclaw-installation-assistant-electron",
  "version": "0.1.3",
  "private": true,
  "description": "OpenClaw 安装助手 - Electron 桌面应用",
  "main": "out/main/index.js",
  "scripts": {
    "postinstall": "node scripts/fix-node-pty.js",
    "generate-icon": "node scripts/generate-icon.js",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "clean": "rm -rf out dist",
    "preview": "electron-vite preview",
    "package:mac": "electron-builder --mac --x64 --arm64",
    "package:win": "electron-builder --win --x64 --arm64",
    "package:linux": "electron-builder --linux"
  },
  "author": "OpenClaw <noreply@openclaw.ai>",
  "license": "MIT",
  "homepage": "https://github.com/shzjj8882/openclaw-installation",
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-toast": "^1.2.2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "json5": "^2.2.3",
    "lucide-react": "^0.460.0",
    "node-pty": "^1.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.49",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.15",
    "typescript": "^5",
    "vite": "^5.4.11"
  },
  "build": {
    "appId": "ai.openclaw.installer",
    "productName": "OpenClaw 安装助手",
    "icon": "build/icon.png",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "build/icon.png"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": ["dmg"],
      "artifactName": "OpenClaw-Installer-${version}-${arch}.${ext}"
    },
    "win": {
      "target": ["nsis"],
      "artifactName": "OpenClaw-Installer-Setup-${version}-${arch}.${ext}"
    },
    "linux": {
      "target": ["deb"],
      "artifactName": "openclaw-installer_${version}_${arch}.${ext}",
      "maintainer": "OpenClaw <noreply@openclaw.ai>"
    }
  }
}
